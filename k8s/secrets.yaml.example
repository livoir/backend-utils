# =============================================================================
# Secret overrides — COPY to k8s/secrets.yaml (gitignored) and fill in real values,
# then deploy with:  helm upgrade --install backend ./k8s -f k8s/values.yaml -f k8s/secrets.yaml -n backend --create-namespace
#
# Keep k8s/secrets.yaml OUT of git. For real production, replace this manual
# approach with External Secrets Operator (pulls from AWS/GCP/Vault) or
# SealedSecrets (encrypted-in-git), so plaintext never sits on disk.
# =============================================================================

kube-prometheus-stack:
  grafana:
    adminPassword: "REPLACE"           # Grafana admin login

postgresql:
  auth:
    password: "REPLACE"                # postgres user password

valkey:
  auth:
    password: "REPLACE"                # cache password (= CACHE_PASSWORD)

minio:
  auth:
    rootUser: "REPLACE"
    rootPassword: "REPLACE"
